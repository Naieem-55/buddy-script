# Local Postgres (already running on 5432)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/buddy_script?schema=public"

# JWT secrets (dev only — generate strong random values in prod)
JWT_ACCESS_SECRET="<random-64-char-hex>"
JWT_REFRESH_SECRET="<random-64-char-hex>"

# Storage: "local" (disk) or "vercel" (Blob)
STORAGE_DRIVER="local"
UPLOAD_DIR="./uploads"

# Cookies
NODE_ENV="development"
