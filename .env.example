# Postgres connection string.
# Local:  postgresql://postgres:postgres@127.0.0.1:5432/buddy_script?schema=public
# Neon:   use the POOLED connection string (ends with -pooler...), add ?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/buddy_script?schema=public"

# JWT secrets — generate strong random values:  openssl rand -hex 32
JWT_ACCESS_SECRET="<random-64-char-hex>"
JWT_REFRESH_SECRET="<random-64-char-hex>"

# Image storage driver: "local" (disk) or "vercel" (Vercel Blob).
# Serverless filesystems are ephemeral, so use "vercel" when deployed to Vercel.
STORAGE_DRIVER="local"

# Only used by the "local" driver.
UPLOAD_DIR="./uploads"

# Only used by the "vercel" driver. On Vercel this is injected automatically
# once a Blob store is connected to the project — no need to set it by hand.
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

NODE_ENV="development"
